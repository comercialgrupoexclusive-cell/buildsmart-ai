NEXT_PUBLIC_DATA_MODE=local
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_SIMPLE_MODEL=gpt-4o-mini
OPENAI_COMPLEX_MODEL=gpt-5-mini
OPENWEATHER_API_KEY=your_openweather_api_key

# WhatsApp Business via Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_LUIZIA_WEBHOOK_URL=https://your-vercel-domain.vercel.app/api/whatsapp/luizia
TWILIO_VALIDATE_SIGNATURE=false

# Google Drive — Service Account (Etapa 3)
# 1. Crie Service Account no Google Cloud Console
# 2. Baixe a chave JSON e compartilhe a pasta Drive com o e-mail da conta
# 3. Preencha abaixo com os dados do JSON:
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END RSA PRIVATE KEY-----\n"
